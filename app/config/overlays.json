{
  "user": {
    "header": [
      {"type": "title", "value": "Benutzerdetails"},
      {"type": "status", "value": "Aktiv", "status": "blue"}
    ],
    "content": [
      {"type": "info-item", "label": "Benutzername", "value": ""},
      {"type": "info-item", "label": "Vorname", "value": ""},
      {"type": "info-item", "label": "Nachname", "value": ""},
      {"type": "info-item", "label": "E-Mail", "value": ""},
      {"type": "info-item", "label": "Rolle", "value": ""}
    ],
    "actions": [
      {"type": "button", "text": "Schließen", "css_class": "btn-secondary", "onclick": "closeOverlay()"},
      {"type": "button", "text": "Bearbeiten", "css_class": "btn-primary", "onclick": ""}
    ]
  },
 "user-form": {
    "header": [
      {"type": "title", "value": "User"},
      {"type": "status", "value": "Hinzufügen", "status": "green"}
    ],
    "content": [
      {
        "type": "form-item",
        "label": "Typ",
        "input": "<div><label><input type='radio' name='typ' value='4'>Extern</label><label><input type='radio' name='typ' value='1' checked>Mitarbeiter</label></div>"
      },
      {
        "type": "form-item",
        "label": "Rolle",
        "input": "<select name='wert'><option value='' selected>Keine Rolle</option><option value='5'>Agent</option><option value='6'>Teamleiter</option><option value='7'>Produktionsleitung</option><option value='8'>Akademie-Coach</option><option value='9'>Akademie-Leitung</option><option value='10'>Personalmanager</option><option value='11'>Steuerung</option><option value='12'>Controlling</option><option value='13'>Produktmanager</option><option value='14'>IT</option><option value='15'>VV-Leitung</option></select>"
      },
      {
        "type": "form-item",
        "label": "Vorname",
        "input": "<input type='text' name='first_name' placeholder='Vorname'>"
      },
      {
        "type": "form-item",
        "label": "Nachname",
        "input": "<input type='text' name='last_name' placeholder='Nachname'>"
      },
      {
        "type": "form-item",
        "label": "E-Mail",
        "input": "<input type='email' name='email' placeholder='E-Mail'>"
      },
      {
        "type": "form-item",
        "label": "Rolle",
        "input": "<input type='text' name='role' placeholder='Rolle'>"
      }
    ],
    "actions": [
      {
        "type": "button",
        "text": "Abbrechen",
        "css_class": "btn-secondary",
        "onclick": "closeOverlay('user-overlay')"
      },
      {
        "type": "button",
        "text": "Speichern",
        "css_class": "btn-primary",
        "submit": true
      }
    ]
  }
}

